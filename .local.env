# ═══════════════════════════════════════════════════════════
#  EXAMPLE configuration — customize all values marked [REPLACE]
#  before deploying to production.
# ═══════════════════════════════════════════════════════════

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=starter
POSTGRES_PASSWORD=starter
POSTGRES_DB=starter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Competition identity ─────────────────────────────────
# [REPLACE] CRUNCH_ID controls the Docker Desktop group name: crunch-node-<CRUNCH_ID>
CRUNCH_ID=starter-challenge
# [REPLACE] Your on-chain crunch address for emissions
CRUNCH_PUBKEY=5xM54EDjcyL6ca7xuBequBgdSS84LpqxVjjSXc695Gf3

# ── Model runner ─────────────────────────────────────────
MODEL_RUNNER_NODE_HOST=model-orchestrator
MODEL_RUNNER_NODE_PORT=9091
MODEL_RUNNER_TIMEOUT_SECONDS=60
MODEL_BASE_CLASSNAME=tracker.TrackerBase

# ── Feed (data source) ──────────────────────────────────
# [REPLACE] Change FEED_SOURCE and FEED_SUBJECTS for your competition
FEED_SOURCE=pyth                        # example: pyth, binance
FEED_SUBJECTS=BTC                       # example: BTC, ETH, SOL (comma-separated for multi-asset)
FEED_KIND=candle
FEED_GRANULARITY=1s
FEED_POLL_SECONDS=5
FEED_BACKFILL_MINUTES=180
FEED_CANDLES_WINDOW=120
FEED_RECORD_TTL_DAYS=90
# FEED_RETENTION_CHECK_SECONDS=3600

# ── Scoring ──────────────────────────────────────────────
# [REPLACE] Point to your real scoring function (the default is a 0.0 stub)
SCORING_FUNCTION=crunch_node.extensions.default_callables:default_score_prediction
SCORE_INTERVAL_SECONDS=5
CHECKPOINT_INTERVAL_SECONDS=60

# ── Checkpoint / Emissions ───────────────────────────────
# CHECKPOINT_INTERVAL_SECONDS=604800    # weekly (default)
# COMPUTE_PROVIDER_PUBKEY=              # [REPLACE] wallet pubkey for compute provider rewards
# DATA_PROVIDER_PUBKEY=                 # [REPLACE] wallet pubkey for data provider rewards

# ── Pyth-specific ────────────────────────────────────────
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_TIMEOUT_SECONDS=5

# ── Scheduled predictions (optional) ─────────────────────
# SCHEDULED_PREDICTION_CONFIGS_PATH=config/scheduled_predictions.json
# Multi-asset example: config/scheduled_prediction_configs.multi_asset.example.json
# Also set FEED_SUBJECTS=BTC,ETH,SOL to ingest data for all assets
