# ── Postgres ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Competition identity ─────────────────────────────────
CRUNCH_ID=starter-challenge
NETWORK=devnet

# ── Model runner ─────────────────────────────────────────
MODEL_RUNNER_NODE_HOST=model-orchestrator
MODEL_RUNNER_NODE_PORT=9091
MODEL_RUNNER_TIMEOUT_SECONDS=120
MODEL_BASE_CLASSNAME=cruncher.BaseClass


# ── Scoring ──────────────────────────────────────────────
SCORING_FUNCTION=starter_challenge.scoring:score_prediction

# ── Timing ───────────────────────────────────────────────
CHECKPOINT_INTERVAL_SECONDS=300

# ── Ports ────────────────────────────────────────────────
REPORT_API_PORT=8000
REPORT_UI_PORT=3000

# ── Web UI ───────────────────────────────────────────────
REPORT_UI_APP=starter
REPORT_UI_BUILD_CONTEXT=../webapp
REPORT_UI_DOCKERFILE=apps/starter/Dockerfile
