POSTGRES_USER=starter
POSTGRES_PASSWORD=starter
POSTGRES_DB=starter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

MODEL_RUNNER_NODE_HOST=model-orchestrator
MODEL_RUNNER_NODE_PORT=9091
MODEL_RUNNER_TIMEOUT_SECONDS=120

# ── Web UI ──────────────────────────────────────────────────────────
REPORT_UI_APP=starter
REPORT_UI_BUILD_CONTEXT=https://github.com/crunchdao/coordinator-webapp.git
REPORT_UI_DOCKERFILE=apps/starter/Dockerfile

# ── Feed: price data for tournament resolution ─────────────────────
FEED_SOURCE=binance
FEED_SUBJECTS=BTCUSDT
FEED_KIND=candle
FEED_GRANULARITY=1m
FEED_POLL_SECONDS=30
FEED_BACKFILL_MINUTES=360
FEED_CANDLES_WINDOW=60
FEED_RECORD_TTL_DAYS=90
FEED_RETENTION_CHECK_SECONDS=3600

CRUNCH_ID=starter-challenge
MODEL_BASE_CLASSNAME=cruncher.BaseModelClass
CHECKPOINT_INTERVAL_SECONDS=300

SCORING_FUNCTION=starter_challenge.scoring:score_prediction
